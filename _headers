# Güvenlik başlıkları — tüm sayfalar
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Statik varlıklar — uzun süreli tarayıcı önbelleği (dosya değişince adı/deploy değişir)
/assets/*
  Cache-Control: public, max-age=604800

/zaman-tuneli/assets/*
  Cache-Control: public, max-age=604800

# Oyun sayfaları tek dosya HTML — hep taze kalsın ki güncellemeler anında görünsün
# (eskiden max-age=3600 idi; oyun güncellemeleri 1 saat gecikmeli çıkıyordu)
/oyun/*
  Cache-Control: public, max-age=0, must-revalidate

# PWA — service worker ve manifest hep taze kalsın (güncellemeler anında yayılsın)
/sw.js
  Cache-Control: no-cache
/manifest.json
  Cache-Control: no-cache
/pwa.js
  Cache-Control: no-cache
